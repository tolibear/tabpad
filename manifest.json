{
  "manifest_version": 3,
  "name": "Tab Pad",
  "version": "1.0.0",
  "description": "Your daily notepad, one page per day, in every new tab. Everything stays on your device.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' data:"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}

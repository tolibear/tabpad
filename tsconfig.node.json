{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "lib": [
      "ES2022"
    ],
    "target": "ES2022",
    "types": [
      "node"
    ]
  },
  "include": [
    "vite.config.ts"
  ]
}

{
  "name": "tab-pad",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Your daily notepad, one page per day, in every new tab.",
  "scripts": {
    "dev": "vite",
    "assets": "node scripts/create-icons.mjs",
    "prebuild": "npm run assets",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "verify:m1": "node scripts/verify-m1.mjs",
    "verify:m2": "node scripts/verify-m2.mjs",
    "verify:m3": "node scripts/verify-m3.mjs",
    "verify:m4": "node scripts/verify-m4.mjs",
    "verify:m5": "node scripts/verify-m5.mjs",
    "verify:m6": "node scripts/verify-m6.mjs",
    "verify:m7": "node scripts/verify-m7.mjs",
    "verify:widgets": "node scripts/verify-widgets.mjs",
    "verify:editor": "node scripts/verify-editor.mjs",
    "verify:extension": "node scripts/verify-extension-cft.mjs",
    "verify:acceptance": "node scripts/verify-acceptance.mjs && node scripts/verify-final-browser.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@lezer/markdown": "^1.6.4",
    "dexie": "^4.4.4",
    "lucide-react": "^0.468.0",
    "markdown-it": "^14.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "fake-indexeddb": "^6.2.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.1"
  }
}
